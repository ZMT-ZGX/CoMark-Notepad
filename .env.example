# Collab Notepad - Environment Variables
# Copy this file to .env and fill in the values

# Required: HMAC signing secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Required for Docker: set your public URL (e.g. https://notepad.example.com)
PUBLIC_ORIGIN=

# Optional: global admin token for managing all pads
ADMIN_TOKEN=

# Optional: session token validity in days (default: 30)
SESSION_TOKEN_TTL_DAYS=30

# Optional: auto-delete files older than N hours (default: 72)
FILE_TTL_HOURS=72

# Optional: server port (default: 8000)
PORT=8000

# Optional: number of proxy hops to trust for X-Forwarded-For (default: 0)
# Set to 1 if behind a reverse proxy (nginx, Caddy, Traefik, etc.)
TRUST_PROXY_HOPS=0

# Optional: max bytes for Markdown conversion (default: 104857600 = 100MB)
# CONVERT_MAX_BYTES=104857600

# Optional: conversion timeout in ms (default: 60000)
# CONVERT_TIMEOUT_MS=60000

